# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (Server-side only - NEVER expose to client)
# Get from Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Auth Redirect (for development with v0 preview)
# This is automatically set by v0 when using Supabase integration
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# Admin Setup Key (one-time use for initial admin setup)
# Set this to a secure random string, use it once, then remove it
ADMIN_SETUP_KEY=your_secure_random_setup_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Code Execution (Piston API)
# Optional: Set this if you have a self-hosted Piston instance
# Leave empty to use the free public API at emkc.org
PISTON_API_URL=https://emkc.org/api/v2/piston/execute

# Optional: Blockchain Service
NEXT_PUBLIC_BLOCKCHAIN_NETWORK=mainnet

# Legacy Firebase Configuration (can be removed if fully migrated to Supabase)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
